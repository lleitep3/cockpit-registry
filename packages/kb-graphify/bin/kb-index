#!/bin/bash

FAST_MODE=false
ROOTS=""

for arg in "$@"; do
    if [ "$arg" = "--fast" ]; then
        FAST_MODE=true
    else
        if [ -n "$ROOTS" ]; then
            ROOTS="$ROOTS $arg"
        else
            ROOTS="$arg"
        fi
    fi
done

API_KEY=$(cockpit vault get kb-graphify.api-key 2>/dev/null)
PROVIDER=$(cockpit vault get kb-graphify.provider 2>/dev/null)

OUT_DIR="$HOME/.cockpit/graphify-out"
mkdir -p "$OUT_DIR"

if [ "$FAST_MODE" = true ] || [ -z "$API_KEY" ]; then
    if [ -z "$API_KEY" ]; then
        echo "No kb-graphify.api-key found in vault. Proceeding with AST-only (fast) extraction."
    fi
    for ROOT in $ROOTS; do
        eval graphify extract "$ROOT" --no-cluster --out "$OUT_DIR"
    done
    exit $?
fi

if [ -z "$PROVIDER" ]; then
    PROVIDER="groq"
fi

if [ "$PROVIDER" = "groq" ]; then
    export OPENAI_API_KEY="$API_KEY"
    export OPENAI_BASE_URL="https://api.groq.com/openai/v1"
    export OPENAI_MODEL="llama-3.1-8b-instant"
    export BACKEND_ARGS="--backend openai --model llama-3.1-8b-instant"
elif [ "$PROVIDER" = "openai" ]; then
    export OPENAI_API_KEY="$API_KEY"
elif [ "$PROVIDER" = "gemini" ]; then
    export GEMINI_API_KEY="$API_KEY"
elif [ "$PROVIDER" = "anthropic" ]; then
    export ANTHROPIC_API_KEY="$API_KEY"
fi

for ROOT in $ROOTS; do
    eval graphify extract $BACKEND_ARGS "$ROOT" --out "$OUT_DIR"

    if [ $? -ne 0 ]; then
        echo "Warning: Graphify LLM extraction failed for $ROOT. Falling back to AST-only extraction..."
        eval graphify extract "$ROOT" --no-cluster --out "$OUT_DIR"
    fi
done
