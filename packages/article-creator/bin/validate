#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ ! -f "$SCRIPT_DIR/article" ]; then
    echo "Error: article binary is missing in bin/ directory."
    exit 1
fi
if [ ! -x "$SCRIPT_DIR/article" ]; then
    echo "Error: article binary is not executable."
    exit 1
fi
echo "article-creator is valid."
exit 0
