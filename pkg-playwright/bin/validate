#!/bin/bash
set -e

# Get the directory of the script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_DIR="$(dirname "$SCRIPT_DIR")"

# Check if node_modules exists
if [ ! -d "$PKG_DIR/node_modules" ]; then
    echo "Playwright dependencies not installed. Running npm install in $PKG_DIR..."
    (cd "$PKG_DIR" && npm install)
fi

# Check if playwright is importable and browser can launch
if ! (cd "$PKG_DIR" && node -e "const { chromium } = require('playwright');") 2>/dev/null; then
    echo "Error: Playwright module not found or failed to load. Please make sure node dependencies are installed."
    exit 1
fi

echo "pkg-playwright is valid."
exit 0
